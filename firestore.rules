rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Leitura liberada para autenticados — necessário para queries de técnicos por empresa.
    match /usuarios/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Todos os dados da empresa (agendamentos, técnicos, equipamentos, etc.)
    // só podem ser acessados por usuários autenticados.
    // Futuramente você pode refinar por role: request.auth.token.role == "gestor"
    match /empresas/{empresaId}/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
