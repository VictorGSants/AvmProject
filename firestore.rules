rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Qualquer usuário autenticado pode listar usuários da mesma empresa
    // (necessário para buscar técnicos via query por empresaId).
    // Escrita bloqueada — só o Admin SDK cria/edita perfis.
    match /usuarios/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Todos os dados da empresa (agendamentos, técnicos, equipamentos, etc.)
    // só podem ser acessados por usuários autenticados.
    // Futuramente você pode refinar por role: request.auth.token.role == "gestor"
    match /empresas/{empresaId}/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
